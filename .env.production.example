# -------------------------------------------------------
# Cloud Run production environment template
# Do NOT commit real values — inject via Secret Manager
# -------------------------------------------------------

APP_NAME=Clairebot API
APP_ENV=production
LOG_LEVEL=INFO

# Google APIs
GOOGLE_API_KEY=<inject-via-secret-manager>
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=dig-cd-rmi-report-qa
GCP_LOCATION=us-central1

# Gemini
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (leave blank if not using)
OPENAI_API_KEY=
OPENAI_MODEL=auto

# Google Sheets (disabled - using CSV export)
ENABLE_SHEETS_WRITER=false
GOOGLE_SHEETS_TEMPLATE_ID=
GOOGLE_SHEETS_OUTPUT_FOLDER_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=Review Findings

# Storage - Cloud Run uses /tmp (ephemeral)
UPLOAD_DIR=/tmp/uploads
PROCESSED_DIR=/tmp/processed
