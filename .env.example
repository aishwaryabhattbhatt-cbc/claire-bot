# App
APP_NAME=Clairebot API
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# Google APIs
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# Gemini
GEMINI_MODEL=gemini-2.0-flash

# LLM Provider (gemini | openai)
LLM_PROVIDER=gemini

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=auto

# Google Sheets
GOOGLE_SHEETS_TEMPLATE_ID=
GOOGLE_SHEETS_OUTPUT_FOLDER_ID=
GOOGLE_SHEETS_WORKSHEET_NAME=Review Findings
ENABLE_SHEETS_WRITER=true

# Document Processing (future steps)
DOC_AI_PROCESSOR_ID=
OCR_PROVIDER=tesseract

# Storage (local for now)
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
